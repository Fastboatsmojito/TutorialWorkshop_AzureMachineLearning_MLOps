# Copy to .env and fill in after provisioning (infra/provision.ps1 writes .azure-resources.json
# with the real values; this file documents what the apps expect).

# ---- Azure subscription / workspace ----
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=rg-tc-aml-foundry-etrm
AZURE_LOCATION=eastus2
AML_WORKSPACE=mlw-tc-etrm

# ---- Azure AI Foundry / Azure OpenAI ----
AOAI_ENDPOINT=https://foundry-tc-etrm.openai.azure.com/
AOAI_API_KEY=
AOAI_DEPLOYMENT=gpt-4o
AOAI_API_VERSION=2024-10-21

# ---- AML managed online endpoint (forecasting model) ----
AML_ENDPOINT_URL=
AML_ENDPOINT_KEY=
